+}
+
+/* =========================
+   Практична робота 2
+   Адаптивність + взаємодія
+   ========================= */
+
+html {
+    font-size: 16px;
+}
+
+img,
+iframe {
+    max-width: 100%;
+    height: auto;
+    display: block;
+}
+
+.messages {
+    transition: opacity 0.5s ease, visibility 0.5s ease;
+}
+
+.messages.is-hidden {
+    opacity: 0;
+    visibility: hidden;
+}
+
+.navbar.is-scrolled {
+    background: rgba(255, 255, 255, 0.98);
+    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.15);
+}
+
+.navbar .container {
+    position: relative;
+    gap: 1rem;
+}
+
+.logo {
+    text-decoration: none;
+}
+
+.mobile-menu-toggle {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    width: 44px;
+    height: 44px;
+    padding: 0;
+    border: 1px solid rgba(45, 80, 22, 0.18);
+    border-radius: 12px;
+}
+
+.nav-menu {
+    display: none;
+    position: absolute;
+    top: calc(100% + 0.5rem);
+    left: 20px;
+    right: 20px;
+    flex-direction: column;
+    gap: 0.5rem;
+    padding: 1rem;
+    background: var(--white);
+    border-radius: 16px;
+    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.14);
+}
+
+.nav-menu.is-open {
+    display: flex;
+}
+
+.nav-menu li {
+    list-style: none;
+}
+
+.nav-menu li a {
+    display: block;
+    padding: 0.85rem 1rem;
+    border-radius: 12px;
+}
+
+.hero {
+    height: auto;
+    min-height: calc(100vh - 76px);
+    padding: 6rem 0 4rem;
+}
+
+.hero-content {
+    width: min(100%, 760px);
+    padding: 0 1rem;
+}
+
+.hero-title {
+    font-size: clamp(1.9rem, 7vw, 3.5rem);
+}
+
+.hero-subtitle {
+    font-size: clamp(1rem, 3.5vw, 1.5rem);
+}
+
+.section-title {
+    font-size: clamp(1.75rem, 5vw, 2.5rem);
+}
+
+.page-header {
+    padding: 3rem 0;
+}
+
+.page-header h1 {
+    font-size: clamp(1.8rem, 5vw, 2.5rem);
+}
+
+.page-header p {
+    font-size: 1rem;
+}
+
+.filters-container {
+    grid-template-columns: 1fr;
+    gap: 1rem;
+}
+
+.filter-buttons {
+    flex-direction: column;
+    align-items: stretch;
+}
+
+.filter-buttons .btn,
+.filter-buttons button,
+.filter-buttons a {
+    width: 100%;
+    text-align: center;
+}
+
+.routes-header,
+.sort-control {
+    flex-direction: column;
+    align-items: stretch;
+}
+
+.sort-control form,
+.sort-control select {
+    width: 100%;
+}
+
+.routes-grid {
+    grid-template-columns: 1fr;
+    gap: 1.5rem;
+}
+
+.route-card,
+.feature-card {
+    height: 100%;
+}
+
+.route-card {
+    display: flex;
+    flex-direction: column;
+}
+
+.route-image {
+    height: 220px;
+}
+
+.route-content {
+    display: flex;
+    flex-direction: column;
+    gap: 1rem;
+    height: 100%;
+}
+
+.route-title {
+    font-size: clamp(1.2rem, 4vw, 1.8rem);
+    margin-bottom: 0;
+}
+
+.route-meta {
+    margin-bottom: 0;
+}
+
+.route-description {
+    margin-bottom: 0;
+    flex-grow: 1;
+}
+
+.route-content .btn {
+    align-self: flex-start;
+    margin-top: auto;
+}
+
+.contacts-content,
+.content-grid,
+.profile-info,
+.route-info-grid,
+.profile-stats {
+    grid-template-columns: 1fr;
+}
+
+.profile-info {
+    gap: 1.5rem;
+    text-align: center;
+}
+
+.profile-avatar {
+    margin: 0 auto;
+}
+
+.contact-item {
+    align-items: flex-start;
+}
+
+.footer .container {
+    display: flex;
+    flex-direction: column;
+    gap: 1rem;
+    text-align: center;
+}
+
+.footer-links {
+    flex-direction: column;
+    gap: 0.75rem;
+}
+
+.pagination {
+    flex-wrap: wrap;
+}
+
+.animate-on-scroll {
+    opacity: 0;
+    transform: translateY(24px);
+    transition: opacity 0.6s ease, transform 0.6s ease;
+}
+
+.animate-on-scroll.is-visible {
+    opacity: 1;
+    transform: translateY(0);
+}
+
+/* 2 картки: 480px–767px */
+@media (min-width: 480px) {
+    .routes-grid {
+        grid-template-columns: repeat(2, minmax(0, 1fr));
+    }
+
+    .route-info-grid,
+    .profile-stats {
+        grid-template-columns: repeat(2, minmax(0, 1fr));
+    }
+
+    .footer-links {
+        flex-direction: row;
+        flex-wrap: wrap;
+        justify-content: center;
+    }
+}
+
+/* Планшет: 768px–1023px */
+@media (min-width: 768px) {
+    .mobile-menu-toggle {
+        display: none;
+    }
+
+    .nav-menu {
+        position: static;
+        display: flex !important;
+        flex-direction: row;
+        align-items: center;
+        gap: 1.25rem;
+        padding: 0;
+        background: transparent;
+        border-radius: 0;
+        box-shadow: none;
+    }
+
+    .nav-menu li a {
+        padding: 0.25rem 0;
+        border-radius: 0;
+    }
+
+    .hero {
+        padding: 7rem 0 5rem;
+    }
+
+    .filters-container {
+        grid-template-columns: repeat(2, minmax(0, 1fr));
+    }
+
+    .filter-buttons {
+        flex-direction: row;
+    }
+
+    .routes-header {
+        flex-direction: row;
+        justify-content: space-between;
+        align-items: center;
+    }
+
+    .sort-control {
+        flex-direction: row;
+        align-items: center;
+        width: auto;
+    }
+
+    .sort-control form {
+        width: auto;
+    }
+
+    .sort-control select {
+        min-width: 220px;
+    }
+
+    .routes-grid {
+        grid-template-columns: repeat(3, minmax(0, 1fr));
+    }
+
+    .contacts-content,
+    .content-grid {
+        grid-template-columns: repeat(2, minmax(0, 1fr));
+    }
+
+    .profile-info {
+        grid-template-columns: auto 1fr;
+        text-align: left;
+        align-items: start;
+    }
+
+    .profile-avatar {
+        margin: 0;
+    }
+
+    .footer .container {
+        flex-direction: row;
+        justify-content: space-between;
+        align-items: center;
+        text-align: left;
+    }
+
+    .footer-links {
+        justify-content: flex-end;
+    }
+}
+
+/* Десктоп: від 1024px */
+@media (min-width: 1024px) {
+    .routes-grid {
+        grid-template-columns: repeat(4, minmax(0, 1fr));
+    }
+
+    .filters-container {
+        grid-template-columns: repeat(5, minmax(0, 1fr));
+    }
+
+    .route-image {
+        height: 240px;
+    }
+}
